<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
<key>NSFaceIDUsageDescription</key>
	<string>Fude uses Face ID to keep your health data private.</string>
	<key>NSCameraUsageDescription</key>
	<string>Fude uses the camera to scan food barcodes.</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- pi.local: Raspberry Pi running the backend on the local network -->
		<!-- localhost: fallback when running the backend directly on the Mac -->
		<!-- All other connections (OpenFoodFacts, USDA proxy in prod) must use HTTPS -->
		<key>NSExceptionDomains</key>
		<dict>
			<key>pi.local</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<false/>
			</dict>
			<key>localhost</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<false/>
			</dict>
		</dict>
	</dict>
</dict>
</plist>
